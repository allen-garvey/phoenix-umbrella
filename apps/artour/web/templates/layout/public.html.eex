<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= site_title assigns[:page_title] %></title>
    <link rel="stylesheet" href="/assets/app.css" />
    <meta name="description" content="The artwork and photography of Allen Garvey" />
    <%= if assigns[:facebook_image] do %>
      <meta property="og:image" content="<%= Artour.ImageView.url_for(@facebook_image, :small) %>" />
    <% end %>
    <%= if assigns[:page_title] do %>
      <meta property="og:title" content="<%= @page_title %>" />
    <% end %>
  </head>

  <body class="<%= assigns[:body_class] %>">
    <header class="header container">
      <nav class="nav">
        <div class="brand"><%= link site_title(), to: ~p"/" %></div>
      </nav>
    </header>

    <%= if assigns[:is_nsfw] do
	      render Artour.PublicPostView, "nsfw_modal.html", conn: @conn
    end %>

    <main class="<%= main_container_class(assigns[:main_container_class]) %>" role="main">
      <%= @inner_content %>
    </main>
    <%= if assigns[:javascript] do %>
      <script src="/assets/app.js"></script>
    <% end %>
  </body>
</html>
