<%= render Bookmarker.SharedView, "form_header.html", heading: "Edit bookmark", back_path: show_path(@bookmark) %>

<%= render "form.html", changeset: @changeset,
						folders: @folders,
                        action: show_path(@bookmark),
                        form_type: :edit %>
<%= CommonWeb.FormView.hidden_delete_form(@conn, show_path(@bookmark)) %>
