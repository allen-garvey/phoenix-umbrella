<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8"/>
    <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <meta name="csrf-token" content={csrf_token_value()}>
    <.live_title prefix="Habits"><%= assigns[:page_title] %></.live_title>
    <link phx-track-static rel="stylesheet" href="/assets/app.css"/>
  </head>
  <body>
    <header class="jumbotron">
      <div class="container main-padding">
        <h1 class="main_title"><%= link "Habits", to: ~p"/" %></h1>
        <nav>
          <ul class="nav">
            <li><%= link "Calendar", to: ~p"/calendar" %></li>
            <li><%= link "Categories", to: ~p"/categories" %></li>
            <li><%= link "Tags", to: ~p"/tags" %></li>
            <li><%= link "Activities", to: ~p"/activities?limit=50" %></li>
            <%= for category <- Habits.Admin.list_favorite_categories(assigns[:categories]) do %>
              <li>
                <%= link HabitsWeb.CategoryView.to_s(category), to: ~p"/categories/#{category}" %>
              </li>
            <% end %>
            <li><%= link "Search", to: ~p"/activities/search" %></li>
            <li><%= link "Add Activity", to: ~p"/activities/new", class: "btn btn-success" %></li>
          </ul>
        </nav>
      </div>
    </header>
    <main class="container">
      <div class="main-padding">
        <p class="alert alert-info" role="alert"><%= Phoenix.Flash.get(@flash, :info) %></p>
        <p class="alert alert-danger" role="alert"><%= Phoenix.Flash.get(@flash, :error) %></p>
      </div>
      <div class={[main_padding(assigns[:no_main_padding]), assigns[:body_class]]}>
        <%= @inner_content %>
      </div>
    </main>
    <script src="/assets/app.js"></script>
  </body>
</html>
