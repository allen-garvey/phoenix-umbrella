<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8"/>
    <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <meta name="csrf-token" content={csrf_token_value()}>
    <.live_title prefix="Pluginista"><%= assigns[:page_title] %></.live_title>
    <link phx-track-static rel="stylesheet" href="/assets/app.css"/>
  </head>
  <body>
    <header class="jumbotron">
      <div class="container">
        <h1 class="main_title"><%= link "Pluginista", to: ~p"/" %></h1>
        <nav>
          <ul class="nav">
            <%= for group <- assigns[:nav_groups] do %>
              <li><%= link group.name, to: ~p"/groups/#{group}" %></li>
            <% end %>
            <li><%= link "Plugins", to: ~p"/plugins?sort=category" %></li>
            <li><%= link "Reports", to: ~p"/reports" %></li>
            <li><%= link "Add Plugin", to: ~p"/plugins/new", class: "btn btn-success" %></li>
          </ul>
        </nav>
      </div>
    </header>
    <div class="container">
      <%= @inner_content %>
    </div>
    <script src="/assets/app.js"></script>
  </body>
</html>
