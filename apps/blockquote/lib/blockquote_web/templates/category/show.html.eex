<%= render BlockquoteWeb.SharedView, "show_header.html",
                                conn: @conn,
                                title: to_s(@category),
                                item_name_singular: @item_name_singular,
                                delete_path: show_path(@category),
                                edit_path: edit_path(@category),
                                item_columns: item_columns(@category)
%>

<%= render BlockquoteWeb.SharedView, "related_fields_list.html",
                                conn: @conn,
                                heading: "Quotes",
                                items: @category.quotes,
                                show_path: &BlockquoteWeb.QuoteView.show_path/1,
                                item_display_func: &BlockquoteWeb.QuoteView.to_excerpt/1
%>
